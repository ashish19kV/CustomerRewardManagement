### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-files
*.bclicense
*.flf
#Test results file
TestResults.xml
# Compiled class file
*.class

# Log file
logs/
*.log
*.log.*.gz
# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
# ignore all target directories and nested content
target/

generated-sources/

# ignore the eclipse .settings directory and all children
.settings/
# ignore other eclipse files as these aspects are managed by the Maven pom.xml
.classpath
.project
